# Shared env for both apps: frontend/landing-page and frontend/admin
# Copy to frontend/.env when running locally.

# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: URL where this frontend is hosted.
APP_URL="MY_APP_URL"
